# Email Insights Agent Configuration

# Anthropic API Key (required)
# Get from: https://console.anthropic.com/api_keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override model (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Optional: Override cron schedule (24-hour format)
# CRON_HOUR=8
# CRON_MINUTE=0

# Optional: Override email batch size
# EMAIL_BATCH_SIZE=50

# Optional: Override initial email count
# MAX_EMAILS_INITIAL=100

# Twilio Configuration (for WhatsApp/SMS conversational agent)
# Get from: https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Optional: Webhook server configuration
# WEBHOOK_PORT=5000
# SKIP_TWILIO_VALIDATION=false

# Optional: Restrict conversational agent to specific phone numbers (comma-separated)
# ALLOWED_PHONE_NUMBERS=whatsapp:+1234567890,whatsapp:+0987654321

# Optional: Conversation history settings
# CONVERSATION_MAX_MESSAGES=20
